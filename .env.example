# ── BACKEND (FastAPI — copy to .env, never commit real values) ─────────────────

# Get from: https://aistudio.google.com/app/apikey (free tier, no credit card)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Get from: Supabase Dashboard → Project → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Get from: Supabase Dashboard → Project → Settings → API → service_role key (keep secret — backend only)
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Your Vercel frontend URL (used for CORS allow-list). Local dev: http://localhost:3000
FRONTEND_URL=https://your-app.vercel.app

# ── FRONTEND (Next.js — copy to frontend/.env.local, never commit real values) ─

# Get from: Supabase Dashboard → Project → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Get from: Supabase Dashboard → Project → Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Your Railway backend URL + /api/v1. Local dev: http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=https://your-backend.railway.app/api/v1
