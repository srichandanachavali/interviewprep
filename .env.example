# Backend — set these in Railway environment variables

GEMINI_API_KEY=           # Google AI Studio → aistudio.google.com → Get API key
SUPABASE_URL=             # Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_SERVICE_KEY=     # Supabase Dashboard → Project Settings → API → service_role key (keep secret)
FRONTEND_URL=             # Your Vercel deployment URL e.g. https://interviewprep.vercel.app

# Frontend — set these in Vercel environment variables

NEXT_PUBLIC_SUPABASE_URL=      # Same as SUPABASE_URL above
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Supabase Dashboard → Project Settings → API → anon/public key
NEXT_PUBLIC_API_URL=           # Your Railway backend URL e.g. https://interviewprep-api.up.railway.app/api/v1
